# MongoDB Connection Configuration
# 
# Copy this file to .env.local and update with your actual credentials
# 
# IMPORTANT: Never commit .env.local to version control
#            This file (.env.example) is safe to commit as it contains no secrets

# MongoDB Atlas Connection String (Production)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database-name
# 
# To get your connection string:
# 1. Go to MongoDB Atlas Dashboard
# 2. Click "Connect" on your cluster
# 3. Choose "Connect your application"
# 4. Copy the connection string
# 5. Replace <password> with your database user password
# 6. Replace <database> with your database name (e.g., timetable-scheduler)
#
# Example:
# MONGODB_URI=mongodb+srv://myuser:mypassword@cluster0.xxxxx.mongodb.net/timetable-scheduler

# Local MongoDB Connection String (Development)
# Format: mongodb://localhost:27017/database-name
#
# Example:
# MONGODB_URI=mongodb://localhost:27017/timetable-scheduler

MONGODB_URI=your_mongodb_connection_string_here
JWT_SECRET=replace_with_a_long_random_secret
EMAIL_USER=your_gmail_address
EMAIL_PASS=your_gmail_app_password
